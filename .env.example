# Database (SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/sentinel.db

# ACLED — Armed Conflict Location & Event Data
ACLED_EMAIL=
ACLED_PASSWORD=

# NASA FIRMS — Fire Information for Resource Management System
FIRMS_MAP_KEY=

# TikTok
TIKTOK_MS_TOKEN=

# Twitter / X
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# OpenAI (for filter + classify stages)
OPENAI_API_KEY=

# Anthropic (for deeper analysis — strategic + assessment stages)
ANTHROPIC_API_KEY=

# AI provider for assessment and strategic stages
# Switch to OpenAI: PIPELINE_ASSESS_PROVIDER=openai, PIPELINE_ASSESS_MODEL=gpt-4.1
# Switch to Claude: PIPELINE_ASSESS_PROVIDER=anthropic, PIPELINE_ASSESS_MODEL=claude-opus-4-6
PIPELINE_ASSESS_PROVIDER=anthropic
PIPELINE_ASSESS_MODEL=claude-opus-4-6
PIPELINE_STRATEGIC_PROVIDER=anthropic
PIPELINE_STRATEGIC_MODEL=claude-opus-4-6

# AWS (for CloudWatch logging)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# CloudWatch
CLOUDWATCH_LOG_GROUP=/sentinel/api
CLOUDWATCH_RETENTION_DAYS=30
# Set to "production" on EC2, "development" locally
CLOUDWATCH_ENVIRONMENT=development

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Scheduler — automatic monitoring loop
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=8
SCHEDULER_TWEETS_PER_ACCOUNT=20
